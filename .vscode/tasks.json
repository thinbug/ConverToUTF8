{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "构建 (Debug)",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"build",
				"ConverToUTF8.csproj",
				"-c",
				"Debug",
				"-r",
				"win-x64",
				"--self-contained"
			],
			"group": "build"
		},
		{
			"label": "发布AOT (x64)",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"publish",
				"-c",
				"Release",
				"-r",
				"win-x64"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			}
		}
	]
}